{
  "name": "nsb-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "test:watch": "node --test --watch",
    "dev": "npx http-server -p 8000 -c-1",
    "dev:cf": "wrangler pages dev . --port 8000",
    "seo:audit": "node scripts/seo-audit.mjs",
    "seo:metrics": "node scripts/seo-metrics.mjs",
    "precommit": "npm test && npm run seo:audit && npm run seo:metrics"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}